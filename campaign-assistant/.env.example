# ─────────────────────────────────────────────────────────────
# LLM Provider
# ─────────────────────────────────────────────────────────────

# Which LLM backend to use. Supported values: anthropic | ollama
LLM_PROVIDER=anthropic

# ─────────────────────────────────────────────────────────────
# Anthropic (cloud) — required when LLM_PROVIDER=anthropic
# ─────────────────────────────────────────────────────────────

# Your Anthropic API key from https://console.anthropic.com/
ANTHROPIC_API_KEY=

# Claude model identifier to use for all requests
ANTHROPIC_MODEL=claude-opus-4-5

# ─────────────────────────────────────────────────────────────
# Ollama (local / offline) — required when LLM_PROVIDER=ollama
# ─────────────────────────────────────────────────────────────

# Base URL of your running Ollama instance
OLLAMA_BASE_URL=http://localhost:11434

# Name of the Ollama model to use (must be pulled with: ollama pull <model>)
# Good options: llama3, mistral, gemma3
OLLAMA_MODEL=llama3

# ─────────────────────────────────────────────────────────────
# Campaign
# ─────────────────────────────────────────────────────────────

# Absolute path to the campaign folder to load (e.g. C:/campaigns/My Campaign)
CAMPAIGN_FOLDER=

# ─────────────────────────────────────────────────────────────
# Storage
# ─────────────────────────────────────────────────────────────

# Path for the local SQLite session database
DATABASE_PATH=./sessions.db
