# ─────────────────────────────────────────────────────────────
# LLM Provider — Phase 1 (local only)
# ─────────────────────────────────────────────────────────────

# Which LLM backend to use.
# Phase 1 supported values: ollama | lmstudio
# Phase 2 will add: anthropic | openai | gemini | groq | mistral
LLM_PROVIDER=ollama

# ─────────────────────────────────────────────────────────────
# Ollama (local GPU) — default provider
# ─────────────────────────────────────────────────────────────

# Base URL of your running Ollama instance
OLLAMA_BASE_URL=http://localhost:11434

# Model to use — must be pulled first with: ollama pull <model>
#
# Options tested on RTX 4060 (8 GB VRAM):
#   llama3.1:8b    4.9 GB | 128k ctx | balanced, recommended default
#   qwen2.5:7b     4.7 GB | 128k ctx | best for structured output / recap
#   mistral:7b     4.4 GB |  32k ctx | fast, proven instruction following
#   gemma3:4b      3.3 GB | 128k ctx | crisp and factual
#   phi4-mini      2.5 GB | 128k ctx | strong reasoning, low VRAM
#   llama3.2:3b    2.0 GB | 128k ctx | fastest, minimal VRAM
OLLAMA_MODEL=llama3.1:8b

# ─────────────────────────────────────────────────────────────
# LM Studio (local GPU, OpenAI-compatible server)
# ─────────────────────────────────────────────────────────────

# Base URL of the LM Studio local server (started from the app)
LMSTUDIO_BASE_URL=http://localhost:1234

# Model identifier — leave blank to auto-detect from /v1/models
LMSTUDIO_MODEL=

# ─────────────────────────────────────────────────────────────
# Campaigns
# ─────────────────────────────────────────────────────────────

# Absolute path to the directory that contains all campaign sub-folders.
# Each sub-folder that contains .md or .txt files will appear in the
# campaign selector dropdown in the sidebar.
CAMPAIGNS_ROOT=

# Optional: pre-select a specific campaign on first launch (full path).
# Leave blank to let the UI pick the first available campaign.
CAMPAIGN_FOLDER=

# ─────────────────────────────────────────────────────────────
# Storage
# ─────────────────────────────────────────────────────────────

# Path for the local SQLite session database
DATABASE_PATH=./sessions.db

